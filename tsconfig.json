{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "references": [
    { "path": "packages/@ronzz/shared-core" },
    { "path": "packages/@ronzz/ui" },
    { "path": "packages/@ronzz/ronstats-core" },
    { "path": "packages/@ronzz/ronlib-core" },
    { "path": "packages/@ronzz/ronencik-core" },
    { "path": "packages/@ronzz/search-core" },
    { "path": "packages/@ronzz/cli" },
    { "path": "apps/web" },
    { "path": "database" }
  ],
  "exclude": ["node_modules", "dist", ".svelte-kit"]
}
