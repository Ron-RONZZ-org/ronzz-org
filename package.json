{
  "name": "ronzz-org",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ronzz/web dev",
    "build": "pnpm --filter @ronzz/web build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "pnpm --filter @ronzz/web check",
    "db:migrate:sqlite": "pnpm --filter database db:migrate:sqlite",
    "db:migrate:pg": "pnpm --filter database db:migrate:pg",
    "db:seed": "pnpm --filter database db:seed",
    "cli": "pnpm --filter @ronzz/cli start",
    "clean": "pnpm -r exec rm -rf node_modules dist .svelte-kit"
  },
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "@node-rs/argon2", "better-sqlite3", "esbuild"]
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "@biomejs/biome": "^1.9.4",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "svelte": "^5.0.0",
    "vitest": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7"
  }
}
